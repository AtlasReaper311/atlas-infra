{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/policy/secret-watch/v1",
  "title": "Atlas Systems secret-watch declaration v1",
  "description": "Names-only secret declarations and redacted plaintext-scan policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner",
    "github_metadata",
    "plaintext_scan",
    "secret_definitions",
    "repositories"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-secret-watch/declaration/v1"
    },
    "owner": {
      "const": "AtlasReaper311/atlas-infra"
    },
    "github_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "token_secret_name"],
      "properties": {
        "mode": {
          "enum": ["optional", "required"]
        },
        "token_secret_name": {
          "const": "SECRET_WATCH_GITHUB_TOKEN"
        }
      }
    },
    "plaintext_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "max_file_bytes",
        "fixture_globs",
        "inline_suppression_marker",
        "suppressions"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_file_bytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 10485760
        },
        "fixture_globs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "inline_suppression_marker": {
          "const": "secret-watch: ignore"
        },
        "suppressions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repository", "path", "line", "rule_id", "owner", "reason"],
            "properties": {
              "repository": {
                "type": "string",
                "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$"
              },
              "path": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
              },
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "rule_id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "expires_at": {
                "type": ["string", "null"],
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "secret_definitions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Z][A-Z0-9_]{1,99}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/secretDefinition"
      }
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repositoryDeclaration"
      }
    }
  },
  "$defs": {
    "rotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "max_age_days": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 3650
        },
        "last_rotated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "secretDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle", "provenance", "rotation"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "lifecycle": {
          "enum": ["active", "deprecated"]
        },
        "provenance": {
          "enum": [
            "github-actions",
            "github-managed",
            "cloudflare-worker",
            "external-provider"
          ]
        },
        "rotation": {
          "$ref": "#/$defs/rotation"
        },
        "replacement": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "scopeDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "store",
        "environment",
        "required_secret_names",
        "optional_secret_names",
        "deprecated_secret_names"
      ],
      "properties": {
        "store": {
          "enum": ["github-actions", "cloudflare-worker", "external-provider"]
        },
        "environment": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,99}$"
        },
        "required_secret_names": {
          "$ref": "#/$defs/secretNameList"
        },
        "optional_secret_names": {
          "$ref": "#/$defs/secretNameList"
        },
        "deprecated_secret_names": {
          "$ref": "#/$defs/secretNameList"
        }
      }
    },
    "secretNameList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]{1,99}$"
      }
    },
    "repositoryDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "classification", "assurance", "scopes"],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$"
        },
        "classification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lifecycle", "scope", "provenance"],
          "properties": {
            "lifecycle": {
              "enum": ["production", "active", "experimental", "deprecated", "archived"]
            },
            "scope": {
              "enum": ["public", "internal"]
            },
            "provenance": {
              "enum": ["original", "external-derived"]
            }
          }
        },
        "assurance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "metadata_required"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "metadata_required": {
              "type": "boolean"
            },
            "exclusion_reason": {
              "type": ["string", "null"],
              "minLength": 1,
              "maxLength": 240
            }
          }
        },
        "scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scopeDeclaration"
          }
        }
      }
    }
  }
}

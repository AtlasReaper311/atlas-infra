{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/policy/v1/public-cloudflare-resources.schema.json",
  "title": "Atlas Systems public Cloudflare resource registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner",
    "reviewed_at",
    "account_id",
    "privacy_model",
    "resources"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-public-cloudflare-resources/v1"
    },
    "owner": {
      "const": "AtlasReaper311/atlas-infra"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "account_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "privacy_model": {
      "const": "declared-public-resources-only; undeclared provider resources are aggregate-only"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/resource"
      }
    }
  },
  "$defs": {
    "service_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "repository": {
      "type": "string",
      "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$",
      "maxLength": 128
    },
    "source_ref": {
      "type": "string",
      "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+:[A-Za-z0-9._/-]+$",
      "maxLength": 240
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_id", "repository", "source_ref"],
      "properties": {
        "service_id": {
          "$ref": "#/$defs/service_id"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "source_ref": {
          "$ref": "#/$defs/source_ref"
        }
      }
    },
    "consumer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_id", "repository", "access", "source_ref"],
      "properties": {
        "service_id": {
          "$ref": "#/$defs/service_id"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "access": {
          "enum": ["read-only", "read-write"]
        },
        "source_ref": {
          "$ref": "#/$defs/source_ref"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "provider_id",
        "display_label",
        "owner",
        "consumers"
      ],
      "properties": {
        "kind": {
          "enum": ["kv-namespace", "d1-database", "r2-bucket"]
        },
        "provider_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{1,128}$"
        },
        "display_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "owner": {
          "$ref": "#/$defs/owner"
        },
        "consumers": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/consumer"
          }
        }
      }
    }
  }
}

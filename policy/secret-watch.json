{
  "schema_version": "atlas-secret-watch/declaration/v1",
  "owner": "AtlasReaper311/atlas-infra",
  "github_metadata": {
    "mode": "optional",
    "token_secret_name": "SECRET_WATCH_GITHUB_TOKEN"
  },
  "plaintext_scan": {
    "enabled": true,
    "max_file_bytes": 1048576,
    "fixture_globs": [
      "contracts/v1/fixtures/**",
      "tests/fixtures/secret-watch/**"
    ],
    "inline_suppression_marker": "secret-watch: ignore",
    "suppressions": []
  },
  "secret_definitions": {
    "CORPUS_SECRET": {
      "owner": "AtlasReaper311",
      "purpose": "Authenticate the bounded corpus refresh operation.",
      "lifecycle": "active",
      "provenance": "external-provider",
      "rotation": {
        "required": true,
        "max_age_days": 180,
        "last_rotated_at": null
      },
      "replacement": null
    },
    "GH_DIGEST_PAT": {
      "owner": "AtlasReaper311",
      "purpose": "Read declared estate repositories for assurance jobs.",
      "lifecycle": "active",
      "provenance": "github-actions",
      "rotation": {
        "required": true,
        "max_age_days": 90,
        "last_rotated_at": null
      },
      "replacement": null
    },
    "NOTIFY_TOKEN": {
      "owner": "AtlasReaper311",
      "purpose": "Submit one bounded assurance summary to atlas-notify.",
      "lifecycle": "active",
      "provenance": "github-actions",
      "rotation": {
        "required": true,
        "max_age_days": 180,
        "last_rotated_at": null
      },
      "replacement": null
    },
    "SECRET_WATCH_GITHUB_TOKEN": {
      "owner": "AtlasReaper311",
      "purpose": "Optionally list GitHub Actions secret names and metadata for selected repositories.",
      "lifecycle": "active",
      "provenance": "github-actions",
      "rotation": {
        "required": true,
        "max_age_days": 90,
        "last_rotated_at": null
      },
      "replacement": null
    }
  },
  "repositories": [
    {
      "repository": "AtlasReaper311/atlas-dep-audit",
      "classification": {
        "lifecycle": "active",
        "scope": "internal",
        "provenance": "original"
      },
      "assurance": {
        "enabled": true,
        "metadata_required": false,
        "exclusion_reason": null
      },
      "scopes": [
        {
          "store": "github-actions",
          "environment": null,
          "required_secret_names": ["GH_DIGEST_PAT"],
          "optional_secret_names": ["NOTIFY_TOKEN", "SECRET_WATCH_GITHUB_TOKEN"],
          "deprecated_secret_names": []
        }
      ]
    },
    {
      "repository": "AtlasReaper311/atlas-infra",
      "classification": {
        "lifecycle": "active",
        "scope": "internal",
        "provenance": "original"
      },
      "assurance": {
        "enabled": true,
        "metadata_required": false,
        "exclusion_reason": null
      },
      "scopes": [
        {
          "store": "github-actions",
          "environment": null,
          "required_secret_names": ["CORPUS_SECRET", "GH_DIGEST_PAT"],
          "optional_secret_names": ["NOTIFY_TOKEN"],
          "deprecated_secret_names": []
        }
      ]
    },
    {
      "repository": "AtlasReaper311/simple-proxy",
      "classification": {
        "lifecycle": "deprecated",
        "scope": "internal",
        "provenance": "external-derived"
      },
      "assurance": {
        "enabled": false,
        "metadata_required": false,
        "exclusion_reason": "Deprecated external-derived repository; excluded from active secret assurance by owner decision."
      },
      "scopes": []
    }
  ]
}

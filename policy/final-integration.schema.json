{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-systems.uk/schemas/final-integration-policy-v1.json",
  "title": "Final integration policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "required_files", "optional_files", "deferred_cutovers", "expected_warning_ids", "allowed_action_permissions", "max_artifact_retention_days", "test_timeout_seconds", "execute_repository_tests"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "required_files": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "optional_files": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "deferred_cutovers": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "state", "reason"], "properties": {"id": {"type": "string"}, "state": {"type": "string"}, "reason": {"type": "string"}}}},
    "expected_warning_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "allowed_action_permissions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "max_artifact_retention_days": {"type": "integer", "minimum": 1, "maximum": 365},
    "test_timeout_seconds": {"type": "integer", "minimum": 30, "maximum": 1800},
    "execute_repository_tests": {"type": "boolean"}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/policy/v1/public-cloudflare-topology.schema.json",
  "title": "Atlas Systems public Cloudflare topology v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner",
    "reviewed_at",
    "account_id",
    "zone_id",
    "privacy_model",
    "storage_policy_ref",
    "workers",
    "pages_projects"
  ],
  "properties": {
    "schema_version": {"const": "atlas-public-cloudflare-topology/v1"},
    "owner": {"const": "AtlasReaper311/atlas-infra"},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "account_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
    "zone_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
    "privacy_model": {
      "const": "declared-public-topology-only; undeclared provider topology is private and aggregate-only"
    },
    "storage_policy_ref": {"const": "policy/public-cloudflare-resources.json"},
    "workers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/worker"}
    },
    "pages_projects": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/pages_project"}
    }
  },
  "$defs": {
    "service_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "repository": {
      "type": "string",
      "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$",
      "maxLength": 128
    },
    "source_ref": {
      "type": "string",
      "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+:[A-Za-z0-9._/-]+$",
      "maxLength": 240
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "custom_domain"],
      "properties": {
        "pattern": {
          "type": "string",
          "pattern": "^[A-Za-z0-9.-]+(?:/[A-Za-z0-9._~!$&'()*+,;=:@%/*-]*)?$",
          "maxLength": 220
        },
        "custom_domain": {"type": "boolean"}
      }
    },
    "service_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding", "service"],
      "properties": {
        "binding": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,63}$"},
        "service": {"$ref": "#/$defs/service_id"}
      }
    },
    "storage_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding", "kind"],
      "properties": {
        "binding": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,63}$"},
        "kind": {"enum": ["kv-namespace", "d1-database", "r2-bucket", "durable-object"]},
        "provider_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"},
        "class_name": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,95}$"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "durable-object"}}},
          "then": {"required": ["class_name"], "not": {"required": ["provider_id"]}}
        },
        {
          "if": {"properties": {"kind": {"enum": ["kv-namespace", "d1-database", "r2-bucket"]}}},
          "then": {"required": ["provider_id"], "not": {"required": ["class_name"]}}
        }
      ]
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_name",
        "service_id",
        "repository",
        "source_ref",
        "routes",
        "metadata_url",
        "service_bindings",
        "storage_bindings"
      ],
      "properties": {
        "script_name": {"$ref": "#/$defs/service_id"},
        "service_id": {"$ref": "#/$defs/service_id"},
        "repository": {"$ref": "#/$defs/repository"},
        "source_ref": {"$ref": "#/$defs/source_ref"},
        "routes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/route"}
        },
        "metadata_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://[^?#]+/_meta$",
          "maxLength": 300
        },
        "service_bindings": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/service_binding"}
        },
        "storage_bindings": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/storage_binding"}
        }
      }
    },
    "pages_project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_name", "repository", "source_ref", "public_surface"],
      "properties": {
        "project_name": {"$ref": "#/$defs/service_id"},
        "repository": {"$ref": "#/$defs/repository"},
        "source_ref": {"$ref": "#/$defs/source_ref"},
        "public_surface": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://[^/?#]+$",
          "maxLength": 200
        }
      }
    }
  }
}

{
  "schema_version": "atlas-control-plane/service-contract/v1",
  "service_id": "atlas-daily-digest",
  "display_name": "Atlas daily digest",
  "owner": {
    "github": "AtlasReaper311",
    "responsibility": "Own scheduled digest generation and bounded delivery."
  },
  "source_repository": "AtlasReaper311/atlas-daily-digest",
  "classification": {
    "lifecycle": "production",
    "scope": "internal",
    "provenance": "original"
  },
  "registry_visibility": "current",
  "runtime": {
    "kind": "cloudflare-worker",
    "deployment_target": "api.atlas-systems.uk/digest",
    "release_identity_supported": false
  },
  "environments": ["production"],
  "routes": [
    {"origin": "https://api.atlas-systems.uk", "path": "/digest/_meta", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://api.atlas-systems.uk", "path": "/digest/health", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://api.atlas-systems.uk", "path": "/digest/run", "methods": ["POST"], "visibility": "authenticated"}
  ],
  "health_endpoint": {"state": "known", "origin": "https://api.atlas-systems.uk", "path": "/digest/health"},
  "metadata_route": "/digest/_meta",
  "metadata_endpoint": {
    "state": "known",
    "origin": "https://api.atlas-systems.uk",
    "path": "/digest/_meta",
    "expected_shape": "worker-meta/v1"
  },
  "dependencies": ["atlas-notify"],
  "slo_refs": [],
  "runbooks": ["docs/runbooks/contract-registry-service-triage.md"],
  "journey_coverage": {"state": "unknown", "references": []},
  "quota_policy": {"state": "unknown", "reference": null},
  "secret_declaration": {"state": "unknown", "reference": null},
  "backup_relevance": {"state": "unknown", "reference": null},
  "release_watch_eligible": false,
  "escalation": {"contact": "github:AtlasReaper311", "policy": "Repository owner review through GitHub."},
  "route_exceptions": [
    {
      "origin": "https://api.atlas-systems.uk",
      "path": "/digest/_meta",
      "reason": "Bounded public service metadata for an internal operational service.",
      "approved_by": "AtlasReaper311"
    },
    {
      "origin": "https://api.atlas-systems.uk",
      "path": "/digest/health",
      "reason": "Bounded liveness required by public estate assurance.",
      "approved_by": "AtlasReaper311"
    }
  ],
  "contract_notes": ["Digest execution remains authenticated; only liveness and metadata are public."],
  "control_plane_policy": {
    "new_features": true,
    "route_ownership": true,
    "default_assurance": true,
    "gardener_remediation": true,
    "deployment_orchestration": true
  }
}

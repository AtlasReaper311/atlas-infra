  "health_endpoint": {"state": "known", "origin": "https://corpus.atlas-systems.uk", "path": "/health"},
  "metadata_route": null,
  "metadata_endpoint": {"state": "unknown", "origin": null, "path": null, "expected_shape": "unknown"},
  "dependencies": [],
  "slo_refs": [],

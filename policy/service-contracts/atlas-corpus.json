    {"origin": "https://corpus.atlas-systems.uk", "path": "/index", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://corpus.atlas-systems.uk", "path": "/refresh", "methods": ["POST"], "visibility": "authenticated"},
    {"origin": "https://corpus.atlas-systems.uk", "path": "/search", "methods": ["GET", "POST"], "visibility": "public"},
    {"origin": "https://corpus.atlas-systems.uk", "path": "/stats", "methods": ["GET"], "visibility": "public"}

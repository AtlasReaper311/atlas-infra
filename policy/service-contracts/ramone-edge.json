{
  "schema_version": "atlas-control-plane/service-contract/v1",
  "service_id": "ramone-edge",
  "display_name": "Ramone edge",
  "owner": {
    "github": "AtlasReaper311",
    "responsibility": "Own the bounded public gateway to local Ramone services."
  },
  "source_repository": "AtlasReaper311/ramone-edge",
  "classification": {
    "lifecycle": "production",
    "scope": "internal",
    "provenance": "original"
  },
  "registry_visibility": "current",
  "runtime": {
    "kind": "cloudflare-worker",
    "deployment_target": "ramone.atlas-systems.uk",
    "release_identity_supported": false
  },
  "environments": ["production"],
  "routes": [
    {"origin": "https://ramone.atlas-systems.uk", "path": "/", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://ramone.atlas-systems.uk", "path": "/_meta", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://ramone.atlas-systems.uk", "path": "/ask", "methods": ["POST"], "visibility": "authenticated"},
    {"origin": "https://ramone.atlas-systems.uk", "path": "/status", "methods": ["GET"], "visibility": "public"}
  ],
  "health_endpoint": {"state": "known", "origin": "https://ramone.atlas-systems.uk", "path": "/status"},
  "metadata_route": "/_meta",
  "metadata_endpoint": {
    "state": "known",
    "origin": "https://ramone.atlas-systems.uk",
    "path": "/_meta",
    "expected_shape": "worker-meta/v1"
  },
  "dependencies": ["ramone-memory", "specular-edge"],
  "slo_refs": [],
  "runbooks": ["docs/runbooks/contract-registry-service-triage.md"],
  "journey_coverage": {
    "state": "present",
    "references": ["AtlasReaper311/atlas-journey-watch:local-ai-state"]
  },
  "quota_policy": {"state": "unknown", "reference": null},
  "secret_declaration": {"state": "unknown", "reference": null},
  "backup_relevance": {"state": "unknown", "reference": null},
  "release_watch_eligible": false,
  "escalation": {"contact": "github:AtlasReaper311", "policy": "Repository owner review through GitHub."},
  "route_exceptions": [
    {
      "origin": "https://ramone.atlas-systems.uk",
      "path": "/",
      "reason": "Approved bounded public interface for the internal local-AI estate.",
      "approved_by": "AtlasReaper311"
    },
    {
      "origin": "https://ramone.atlas-systems.uk",
      "path": "/_meta",
      "reason": "Bounded public service metadata for an internal gateway.",
      "approved_by": "AtlasReaper311"
    },
    {
      "origin": "https://ramone.atlas-systems.uk",
      "path": "/status",
      "reason": "Bounded availability state is an approved public read surface.",
      "approved_by": "AtlasReaper311"
    }
  ],
  "contract_notes": ["Protected ask remains authenticated by its existing edge controls."],
  "control_plane_policy": {
    "new_features": true,
    "route_ownership": true,
    "default_assurance": true,
    "gardener_remediation": true,
    "deployment_orchestration": true
  }
}

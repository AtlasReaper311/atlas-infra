    {"origin": "https://api.atlas-systems.uk", "path": "/v1/control-plane/tools/services/{service_id}", "methods": ["GET"], "visibility": "authenticated"},
    {"origin": "https://api.atlas-systems.uk", "path": "/v1/control-plane/tools/summary", "methods": ["GET"], "visibility": "authenticated"},
    {"origin": "https://api.atlas-systems.uk", "path": "/v1/docs", "methods": ["GET"], "visibility": "public"},

    {"origin": "https://api.atlas-systems.uk", "path": "/v1/registry", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://api.atlas-systems.uk", "path": "/v1/search", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://api.atlas-systems.uk", "path": "/v1/slo", "methods": ["GET"], "visibility": "public"},
    {"origin": "https://api.atlas-systems.uk", "path": "/v1/stats", "methods": ["GET"], "visibility": "public"}

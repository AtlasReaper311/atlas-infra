{
  "schema_version": "atlas-control-plane/fingerprint-rules/v1",
  "canonicalization": {
    "encoding": "UTF-8",
    "json": "RFC 8259 object with lexicographically sorted keys and compact separators",
    "unicode": "preserved without ASCII escaping",
    "digest": "SHA-256 lowercase hexadecimal"
  },
  "rules": {
    "evidence-envelope": {
      "kind": "payload-digest",
      "schema": "evidence-envelope.schema.json",
      "content_path": "payload",
      "output_path": "digest.value"
    },
    "finding": {
      "kind": "selected-fields",
      "schema": "finding.schema.json",
      "fields": [
        "source.producer",
        "source.check_id",
        "subject.repository",
        "subject.service_id",
        "category",
        "rule_id",
        "location"
      ],
      "sort_arrays": [],
      "prefix": "sha256:",
      "output_path": "fingerprint"
    },
    "remediation-proposal": {
      "kind": "selected-fields",
      "schema": "remediation-proposal.schema.json",
      "fields": [
        "finding_fingerprint",
        "fixer.id",
        "fixer.version",
        "files_affected",
        "patch_digest"
      ],
      "sort_arrays": [
        "files_affected"
      ],
      "prefix": "proposal:sha256:",
      "output_path": "proposal_id"
    }
  },
  "trace_rules": {
    "evidence-node": {
      "kind": "selected-fields",
      "schema": "evidence-node.schema.json",
      "fields": [
        "kind",
        "identity.key"
      ],
      "sort_arrays": [],
      "prefix": "node:sha256:",
      "output_path": "node_id"
    },
    "evidence-edge": {
      "kind": "selected-fields",
      "schema": "evidence-edge.schema.json",
      "fields": [
        "from_node",
        "relation",
        "to_node"
      ],
      "sort_arrays": [],
      "prefix": "edge:sha256:",
      "output_path": "edge_id"
    },
    "evidence-graph": {
      "kind": "selected-fields",
      "schema": "evidence-graph.schema.json",
      "fields": [
        "visibility",
        "nodes",
        "edges"
      ],
      "sort_arrays": [
        "nodes",
        "edges"
      ],
      "prefix": "graph:sha256:",
      "output_path": "fingerprint"
    }
  },
  "wave3_rules": {
    "retirement-evidence": {
      "kind": "selected-fields",
      "schema": "retirement-evidence.schema.json",
      "fields": [
        "subject",
        "state",
        "evidence",
        "visibility",
        "recorded_at",
        "approved_by"
      ],
      "sort_arrays": [],
      "prefix": "retirement:sha256:",
      "output_path": "retirement_id"
    },
    "adr-runtime-relationship": {
      "kind": "selected-fields",
      "schema": "adr-runtime-relationship.schema.json",
      "fields": [
        "adr",
        "affects.repositories",
        "affects.services",
        "affects.contracts",
        "affects.policies",
        "visibility"
      ],
      "sort_arrays": [
        "affects.repositories",
        "affects.services",
        "affects.contracts",
        "affects.policies"
      ],
      "prefix": "adrrel:sha256:",
      "output_path": "relationship_id"
    },
    "model-promotion": {
      "kind": "selected-fields",
      "schema": "model-promotion.schema.json",
      "fields": [
        "capability",
        "model",
        "configuration",
        "evaluation",
        "approval",
        "visibility"
      ],
      "sort_arrays": [],
      "prefix": "promotion:sha256:",
      "output_path": "promotion_id"
    }
  }
}

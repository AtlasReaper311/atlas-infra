{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/release-reliability-correlation.schema.json",
  "title": "Atlas Systems ReleaseReliabilityCorrelation v1",
  "description": "Day-granular before and after reliability observations around detected releases. Every record is correlation evidence, never a causal claim, and absent data is stated, never treated as safety.",
  "type": "object",
  "additionalProperties": false,
  "x-owner": {
    "repository": "AtlasReaper311/atlas-infra",
    "consumer": "atlas-dora /dora/releases, incident evidence pack"
  },
  "required": [
    "schema_version",
    "generated_at",
    "stale_after",
    "basis",
    "releases"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-control-plane/release-reliability-correlation/v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stale_after": {
      "type": "string",
      "format": "date-time"
    },
    "basis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    },
    "releases": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repository",
          "service_id",
          "deploy_event_at",
          "deploy_event_source",
          "windows",
          "pre",
          "post",
          "deltas",
          "scheduled_journey_state",
          "verification",
          "evidence_sufficiency",
          "suspected_regression",
          "correlation_not_causation",
          "confidence"
        ],
        "properties": {
          "repository": {
            "type": "string",
            "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$",
            "maxLength": 128
          },
          "service_id": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 64
          },
          "deploy_event_at": {
            "type": "string",
            "format": "date-time"
          },
          "deploy_event_source": {
            "enum": ["atlas-notify/notify/recent"]
          },
          "windows": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pre_days", "post_days", "excluded_mixed_day"],
            "properties": {
              "pre_days": {
                "type": "array",
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              },
              "post_days": {
                "type": "array",
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              },
              "excluded_mixed_day": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              }
            }
          },
          "pre": {
            "$ref": "#/$defs/WindowObservation"
          },
          "post": {
            "$ref": "#/$defs/WindowObservation"
          },
          "deltas": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "availability_pct_change",
              "avg_ms_change",
              "failure_rate_change"
            ],
            "properties": {
              "availability_pct_change": {
                "type": ["number", "null"]
              },
              "avg_ms_change": {
                "type": ["number", "null"]
              },
              "failure_rate_change": {
                "type": ["number", "null"]
              }
            }
          },
          "scheduled_journey_state": {
            "enum": ["healthy", "degraded", "down", "unknown"]
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "reference"],
            "properties": {
              "state": {
                "enum": ["available", "unavailable-from-public-surface"]
              },
              "reference": {
                "type": ["string", "null"],
                "maxLength": 240
              }
            }
          },
          "evidence_sufficiency": {
            "enum": ["sufficient", "partial", "insufficient"]
          },
          "suspected_regression": {
            "type": ["boolean", "null"]
          },
          "correlation_not_causation": {
            "const": true
          },
          "confidence": {
            "enum": ["high", "medium", "low", "none"]
          }
        }
      }
    }
  },
  "$defs": {
    "WindowObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability_pct", "avg_ms", "samples"],
      "properties": {
        "availability_pct": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "avg_ms": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "samples": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "atlas-control-plane/release-reliability-correlation/v1",
      "generated_at": "2026-07-19T12:00:00Z",
      "stale_after": "2026-07-19T12:30:00Z",
      "basis": "deploy events from the atlas-notify ring buffer correlated against atlas-api-public per-day probe counters; release day excluded as mixed",
      "releases": [
        {
          "repository": "AtlasReaper311/atlas-notify",
          "service_id": "atlas-notify",
          "deploy_event_at": "2026-07-16T14:12:00Z",
          "deploy_event_source": "atlas-notify/notify/recent",
          "windows": {
            "pre_days": ["2026-07-13", "2026-07-14", "2026-07-15"],
            "post_days": ["2026-07-17", "2026-07-18"],
            "excluded_mixed_day": "2026-07-16"
          },
          "pre": {
            "availability_pct": 99.77,
            "avg_ms": 190,
            "samples": 432
          },
          "post": {
            "availability_pct": 99.65,
            "avg_ms": 201,
            "samples": 288
          },
          "deltas": {
            "availability_pct_change": -0.12,
            "avg_ms_change": 11,
            "failure_rate_change": 0.0012
          },
          "scheduled_journey_state": "healthy",
          "verification": {
            "state": "unavailable-from-public-surface",
            "reference": null
          },
          "evidence_sufficiency": "partial",
          "suspected_regression": false,
          "correlation_not_causation": true,
          "confidence": "medium"
        }
      ]
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/public-repository-classifications.schema.json",
  "title": "Atlas Systems public repository classification projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority",
    "sources",
    "source_fingerprint",
    "repository_count",
    "repositories"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-public-repository-classifications/projection/v1"
    },
    "authority": {
      "const": "AtlasReaper311/atlas-infra"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_registry", "public_non_runtime"],
      "properties": {
        "runtime_registry": {
          "const": "policy/estate-registry.json"
        },
        "public_non_runtime": {
          "const": "policy/public-assurance-repositories.json"
        }
      }
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "repository_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repository",
          "lifecycle",
          "scope",
          "provenance",
          "runtime_service"
        ],
        "properties": {
          "repository": {
            "type": "string",
            "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$",
            "maxLength": 128
          },
          "lifecycle": {
            "enum": ["production", "active", "experimental", "deprecated", "archived"]
          },
          "scope": {
            "enum": ["public", "internal"]
          },
          "provenance": {
            "enum": ["original", "external-derived"]
          },
          "runtime_service": {
            "type": "boolean"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/model-promotion.schema.json",
  "title": "Atlas Systems ModelPromotion v1",
  "description": "A human-approved model and configuration promotion record tied to exact evaluation evidence. It carries evidence only and grants no model installation or routing authority.",
  "type": "object",
  "additionalProperties": false,
  "x-owner": {
    "repository": "AtlasReaper311/atlas-infra",
    "consumer": "atlas-eval-harness promotion evidence and future sanitized Atlas Trace projection"
  },
  "required": [
    "schema_version",
    "promotion_id",
    "capability",
    "model",
    "configuration",
    "evaluation",
    "approval",
    "visibility"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-control-plane/model-promotion/v1"
    },
    "promotion_id": {
      "type": "string",
      "pattern": "^promotion:sha256:[0-9a-f]{64}$"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 80
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+(?::[A-Za-z0-9._-]+)?$",
          "maxLength": 120
        },
        "digest": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_fingerprint",
        "retrieval_policy_fingerprint",
        "corpus_snapshot",
        "runtime_options_fingerprint"
      ],
      "properties": {
        "prompt_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "retrieval_policy_fingerprint": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "corpus_snapshot": {
          "type": ["string", "null"],
          "pattern": "^(?:sha256:[0-9a-f]{64}|[A-Za-z0-9._/-]{1,160})$"
        },
        "runtime_options_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_revision",
        "evidence_fingerprint",
        "evidence_uri",
        "pass_rate",
        "minimum_pass_rate"
      ],
      "properties": {
        "suite_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "evidence_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "evidence_uri": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://[^?#]+(?:#[A-Za-z0-9._/-]+)?$",
          "maxLength": 500
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_by", "approved_at"],
      "properties": {
        "approved_by": {
          "const": "AtlasReaper311"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "supersedes": {
      "type": "string",
      "pattern": "^promotion:sha256:[0-9a-f]{64}$"
    },
    "visibility": {
      "enum": ["public", "internal", "restricted-metadata"]
    },
    "note": {
      "type": "string",
      "maxLength": 500
    }
  },
  "examples": [
    {
      "schema_version": "atlas-control-plane/model-promotion/v1",
      "promotion_id": "promotion:sha256:7d575e9f4a051701dbd51346fca043db095325ec228b1425feb08102fbe6ece6",
      "capability": "postmortem-drafting",
      "model": {
        "name": "qwen3:14b",
        "digest": "sha256:1111111111111111111111111111111111111111111111111111111111111111"
      },
      "configuration": {
        "prompt_fingerprint": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
        "retrieval_policy_fingerprint": null,
        "corpus_snapshot": null,
        "runtime_options_fingerprint": "sha256:3333333333333333333333333333333333333333333333333333333333333333"
      },
      "evaluation": {
        "suite_revision": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "evidence_fingerprint": "sha256:4444444444444444444444444444444444444444444444444444444444444444",
        "evidence_uri": "https://github.com/AtlasReaper311/atlas-eval-harness/actions/runs/100",
        "pass_rate": 1.0,
        "minimum_pass_rate": 1.0
      },
      "approval": {
        "approved_by": "AtlasReaper311",
        "approved_at": "2026-07-21T22:30:00Z"
      },
      "visibility": "internal"
    }
  ]
}

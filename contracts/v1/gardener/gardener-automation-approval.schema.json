{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/gardener-automation-approval.schema.json",
  "title": "Atlas Gardener AutomationApproval v1",
  "description": "A non-interactive approval bound to exact authority, finding, proposal, plan, repository state, patch, workflow run and expiry.",
  "type": "object",
  "additionalProperties": false,
  "x-owner": {
    "repository": "AtlasReaper311/atlas-infra",
    "consumer": "AtlasReaper311/atlas-gardener"
  },
  "required": [
    "schema_version",
    "approval_id",
    "remediation_key",
    "policy_digest",
    "coverage_digest",
    "bundle_digest",
    "finding_fingerprint",
    "proposal_id",
    "plan_digest",
    "repository",
    "classification",
    "classification_fingerprint",
    "rule_id",
    "fixer",
    "base_branch",
    "base_sha",
    "expected_head_sha",
    "files",
    "patch_digest",
    "risk_class",
    "mode",
    "source_run",
    "controller_run",
    "issued_at",
    "expires_at"
  ],
  "properties": {
    "schema_version": {"const": "atlas-control-plane/gardener-automation-approval/v1"},
    "approval_id": {"type": "string", "pattern": "^approval:sha256:[0-9a-f]{64}$"},
    "remediation_key": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "policy_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "coverage_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "bundle_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "finding_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "proposal_id": {"type": "string", "pattern": "^proposal:sha256:[0-9a-f]{64}$"},
    "plan_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "repository": {"type": "string", "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$", "maxLength": 128},
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle", "scope", "provenance"],
      "properties": {
        "lifecycle": {"enum": ["active", "production"]},
        "scope": {"enum": ["internal", "public"]},
        "provenance": {"const": "original"}
      }
    },
    "classification_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "rule_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 96},
    "fixer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"enum": ["macos-metadata-ignore", "python-cache-ignore", "workflow-timeout", "workflow-permissions", "action-pin-plan"]},
        "version": {"type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$"}
      }
    },
    "base_branch": {"type": "string", "pattern": "^[A-Za-z0-9._/-]{1,120}$"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "expected_head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mode", "before_sha256", "after_sha256"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)[.][.](?:/|$))[A-Za-z0-9._/-]+$", "maxLength": 240},
          "mode": {"enum": ["100644", "100755"]},
          "before_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "after_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "patch_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "risk_class": {"enum": ["low", "review-required"]},
    "mode": {"enum": ["observe", "pr-only", "automerge-low-risk"]},
    "source_run": {"$ref": "#/$defs/run"},
    "controller_run": {"$ref": "#/$defs/run"},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "workflow", "run_id", "run_attempt", "commit"],
      "properties": {
        "repository": {"type": "string", "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$"},
        "workflow": {"type": "string", "pattern": "^[.]github/workflows/[A-Za-z0-9._-]+[.]ya?ml$"},
        "run_id": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
        "run_attempt": {"type": "integer", "minimum": 1, "maximum": 100},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    }
  }
}

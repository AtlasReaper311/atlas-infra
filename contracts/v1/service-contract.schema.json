{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/service-contract.schema.json",
  "title": "Atlas Systems ServiceContract v1",
  "description": "A stable service or historical dependency declaration with separate classification axes.",
  "type": "object",
  "additionalProperties": false,
  "x-owner": {
    "repository": "AtlasReaper311/atlas-infra",
    "consumer": "canonical registry and assurance tooling"
  },
  "required": [
    "schema_version",
    "service_id",
    "display_name",
    "owner",
    "source_repository",
    "classification",
    "registry_visibility",
    "runtime",
    "routes",
    "metadata_route",
    "dependencies",
    "slo_refs",
    "runbooks",
    "control_plane_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-control-plane/service-contract/v1"
    },
    "service_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github", "responsibility"],
      "properties": {
        "github": {
          "type": "string",
          "pattern": "^[A-Za-z0-9-]{1,39}$"
        },
        "responsibility": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "source_repository": {
      "type": "string",
      "pattern": "^AtlasReaper311/[A-Za-z0-9._-]+$",
      "maxLength": 128
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle", "scope", "provenance"],
      "properties": {
        "lifecycle": {
          "enum": ["production", "active", "experimental", "deprecated", "archived"]
        },
        "scope": {
          "enum": ["public", "internal"]
        },
        "provenance": {
          "enum": ["original", "external-derived"]
        }
      }
    },
    "registry_visibility": {
      "enum": ["current", "historical"]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "deployment_target", "release_identity_supported"],
      "properties": {
        "kind": {
          "enum": [
            "cloudflare-worker",
            "cloudflare-pages",
            "local-service",
            "library",
            "tool",
            "external-derived"
          ]
        },
        "deployment_target": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[a-z0-9 .:/_-]*[a-z0-9])?$",
          "maxLength": 160
        },
        "release_identity_supported": {
          "type": "boolean"
        }
      }
    },
    "routes": {
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "methods", "visibility"],
        "properties": {
          "origin": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://[^/?#]+$",
            "maxLength": 200
          },
          "path": {
            "type": "string",
            "pattern": "^/(?:[A-Za-z0-9._~!$&'()*+,;=:@%/-]|\\{[a-z][a-z0-9_]*\\})*$",
            "maxLength": 200
          },
          "methods": {
            "type": "array",
            "minItems": 1,
            "maxItems": 7,
            "uniqueItems": true,
            "items": {
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
            }
          },
          "visibility": {
            "enum": ["public", "authenticated", "internal"]
          }
        }
      }
    },
    "metadata_route": {
      "type": ["string", "null"],
      "pattern": "^/(?:[A-Za-z0-9._~!$&'()*+,;=:@%/-]+/)?_meta$",
      "maxLength": 200
    },
    "dependencies": {
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "maxLength": 64
      }
    },
    "slo_refs": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$",
        "maxLength": 240
      }
    },
    "runbooks": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.md$",
        "maxLength": 240
      }
    },
    "control_plane_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_features",
        "route_ownership",
        "default_assurance",
        "gardener_remediation",
        "deployment_orchestration"
      ],
      "properties": {
        "new_features": {"type": "boolean"},
        "route_ownership": {"type": "boolean"},
        "default_assurance": {"type": "boolean"},
        "gardener_remediation": {"type": "boolean"},
        "deployment_orchestration": {"type": "boolean"}
      }
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": ["development", "preview", "production", "local", "unknown"]
      }
    },
    "health_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "origin", "path"],
      "properties": {
        "state": {"enum": ["known", "unknown", "not-applicable"]},
        "origin": {
          "type": ["string", "null"],
          "format": "uri",
          "pattern": "^https://[^/?#]+$",
          "maxLength": 200
        },
        "path": {
          "type": ["string", "null"],
          "pattern": "^/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*$",
          "maxLength": 200
        }
      }
    },
    "metadata_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "origin", "path", "expected_shape"],
      "properties": {
        "state": {"enum": ["known", "unknown", "not-applicable"]},
        "origin": {
          "type": ["string", "null"],
          "format": "uri",
          "pattern": "^https://[^/?#]+$",
          "maxLength": 200
        },
        "path": {
          "type": ["string", "null"],
          "pattern": "^/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*$",
          "maxLength": 200
        },
        "expected_shape": {
          "enum": [
            "worker-meta/v1",
            "html-build-meta/v1",
            "service-specific",
            "unknown",
            "not-applicable"
          ]
        }
      }
    },
    "journey_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "references"],
      "properties": {
        "state": {"enum": ["present", "absent", "unknown", "not-applicable"]},
        "references": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 240}
        }
      }
    },
    "quota_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reference"],
      "properties": {
        "state": {"enum": ["present", "absent", "unknown", "not-applicable"]},
        "reference": {
          "type": ["string", "null"],
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$",
          "maxLength": 240
        }
      }
    },
    "secret_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reference"],
      "properties": {
        "state": {"enum": ["present", "absent", "unknown", "not-applicable"]},
        "reference": {
          "type": ["string", "null"],
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$",
          "maxLength": 240
        }
      }
    },
    "backup_relevance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reference"],
      "properties": {
        "state": {"enum": ["relevant", "not-relevant", "unknown"]},
        "reference": {
          "type": ["string", "null"],
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$",
          "maxLength": 240
        }
      }
    },
    "release_watch_eligible": {"type": "boolean"},
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contact", "policy"],
      "properties": {
        "contact": {"type": "string", "minLength": 1, "maxLength": 120},
        "policy": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    },
    "route_exceptions": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["origin", "path", "reason", "approved_by"],
        "properties": {
          "origin": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://[^/?#]+$",
            "maxLength": 200
          },
          "path": {
            "type": "string",
            "pattern": "^/[A-Za-z0-9._~!$&'()*+,;=:@%/-]*$",
            "maxLength": 200
          },
          "reason": {"type": "string", "minLength": 1, "maxLength": 240},
          "approved_by": {"type": "string", "pattern": "^[A-Za-z0-9-]{1,39}$"}
        }
      }
    },
    "contract_notes": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 300}
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["source_repository"],
        "properties": {
          "source_repository": {"const": "AtlasReaper311/simple-proxy"}
        }
      },
      "then": {
        "properties": {
          "service_id": {"const": "simple-proxy"},
          "classification": {
            "properties": {
              "lifecycle": {"const": "deprecated"},
              "scope": {"const": "internal"},
              "provenance": {"const": "external-derived"}
            }
          },
          "registry_visibility": {"const": "historical"},
          "routes": {"maxItems": 0},
          "metadata_route": {"const": null},
          "control_plane_policy": {
            "properties": {
              "new_features": {"const": false},
              "route_ownership": {"const": false},
              "default_assurance": {"const": false},
              "gardener_remediation": {"const": false},
              "deployment_orchestration": {"const": false}
            }
          }
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "atlas-control-plane/service-contract/v1",
      "service_id": "simple-proxy",
      "display_name": "simple-proxy historical dependency",
      "owner": {
        "github": "AtlasReaper311",
        "responsibility": "Retain attribution and dependency history only."
      },
      "source_repository": "AtlasReaper311/simple-proxy",
      "classification": {
        "lifecycle": "deprecated",
        "scope": "internal",
        "provenance": "external-derived"
      },
      "registry_visibility": "historical",
      "runtime": {
        "kind": "external-derived",
        "deployment_target": "historical-only",
        "release_identity_supported": false
      },
      "routes": [],
      "metadata_route": null,
      "dependencies": [],
      "slo_refs": [],
      "runbooks": [],
      "control_plane_policy": {
        "new_features": false,
        "route_ownership": false,
        "default_assurance": false,
        "gardener_remediation": false,
        "deployment_orchestration": false
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.atlas-systems.uk/control-plane/v1/remediation-proposal.schema.json",
  "title": "Atlas Systems RemediationProposal v1",
  "description": "A review-only remediation plan with inert validation commands.",
  "type": "object",
  "additionalProperties": false,
  "x-owner": {
    "repository": "AtlasReaper311/atlas-infra",
    "consumer": "future atlas-gardener after a separate Phase 2 gate"
  },
  "required": [
    "schema_version",
    "proposal_id",
    "finding_fingerprint",
    "fixer",
    "files_affected",
    "risk_class",
    "patch_digest",
    "validation_plan",
    "rollback_plan",
    "expires_at"
  ],
  "properties": {
    "schema_version": {
      "const": "atlas-control-plane/remediation-proposal/v1"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^proposal:sha256:[0-9a-f]{64}$"
    },
    "finding_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "fixer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "maxLength": 96
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "files_affected": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$",
        "maxLength": 240
      }
    },
    "risk_class": {
      "enum": ["low", "medium", "high"]
    },
    "patch_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "validation_plan": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "command", "expected"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 64
          },
          "command": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_./:= -]+$",
            "minLength": 1,
            "maxLength": 240
          },
          "expected": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "rollback_plan": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "examples": [
    {
      "schema_version": "atlas-control-plane/remediation-proposal/v1",
      "proposal_id": "proposal:sha256:7f4b0b3abed2ee3bd7b3a291155aad38df2539d648394bd74ca704324b837ec5",
      "finding_fingerprint": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "fixer": {
        "id": "add-ds-store-ignore",
        "version": "1.0.0"
      },
      "files_affected": [
        ".gitignore"
      ],
      "risk_class": "low",
      "patch_digest": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
      "validation_plan": [
        {
          "check_id": "repository-tests",
          "command": "python3 -m unittest discover -s tests -v",
          "expected": "All repository tests pass."
        }
      ],
      "rollback_plan": [
        "Close the unmerged review branch and leave main unchanged."
      ],
      "expires_at": "2026-07-21T10:00:00Z"
    }
  ]
}
